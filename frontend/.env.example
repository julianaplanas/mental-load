# ─── Backend URL ─────────────────────────────────────────────────────────────
# Set to your Railway backend URL after deploying.
VITE_API_URL=https://your-noi-backend.railway.app

# ─── Web Push ────────────────────────────────────────────────────────────────
# Copy the VAPID_PUBLIC_KEY from backend/.env here.
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ─── Local development ───────────────────────────────────────────────────────
# VITE_API_URL=http://localhost:3000
