# ─── Backend URL ─────────────────────────────────────────────────────────────
# Set this to your Railway backend URL after deploying.
# Must start with https:// for production builds.
EXPO_PUBLIC_API_URL=https://your-noi-backend.railway.app

# ─── Local development ───────────────────────────────────────────────────────
# For local dev, comment out the line above and use your machine's local IP.
# Find it with: ipconfig getifaddr en0  (macOS) or hostname -I  (Linux)
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000
