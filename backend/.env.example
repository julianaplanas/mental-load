# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — copy from Railway → your project → Variables tab
DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── Server ──────────────────────────────────────────────────────────────────
# Railway sets PORT automatically. Keep default for local dev.
PORT=3000

# Node environment (set to "production" on Railway)
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Allowed origin for CORS. For Expo Go / local dev you can set this to *
# In production, set to your Railway backend public URL
FRONTEND_URL=http://localhost:8081

# ─── Notifications & Scheduling ──────────────────────────────────────────────
# IANA timezone name used for:
#   - Scheduled jobs (9 AM daily reminders, Sunday 10 AM digest)
#   - Do Not Disturb window (10 PM – 8 AM)
# Find yours: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=America/Argentina/Buenos_Aires
