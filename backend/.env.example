# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string — copy from Railway → your project → Variables tab
DATABASE_URL=postgresql://user:password@host:port/dbname

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Set to your Railway frontend URL in production, or * for open access
FRONTEND_URL=http://localhost:5173

# ─── Notifications & Scheduling ──────────────────────────────────────────────
# IANA timezone name for scheduled jobs and DND window
TIMEZONE=America/Argentina/Buenos_Aires

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate once with: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
# Then copy the output here. Never regenerate these — all existing subscriptions will break.
VAPID_SUBJECT=mailto:your@email.com
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
